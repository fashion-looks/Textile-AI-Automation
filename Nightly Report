name: Nightly Report

on:
  schedule:
    - cron: "0 20 * * *"

jobs:
  report:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - run: pip install -r requirements.txt

      - run: python src/report_generator.py
