name: Instagram Growth Dashboard

on:
  schedule:
    - cron: "0 15 * * *"   # 8:30 PM IST
  workflow_dispatch:

jobs:
  dashboard:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - run: pip install -r requirements.txt

      - run: python automation/trend_tracker.py
      - run: python automation/engagement_report.py
      - run: python automation/hashtag_analyzer.py

      - uses: actions/upload-artifact@v4
        with:
          name: instagram-dashboard
          path: dashboard/
